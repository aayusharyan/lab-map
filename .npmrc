# ----------------------------------------------------------------------------
# pnpm Configuration
# ----------------------------------------------------------------------------
# This file configures pnpm behavior for this project.
# Documentation: https://pnpm.io/npmrc

# ----------------------------------------------------------------------------
# Security & Scripts
# ----------------------------------------------------------------------------
# Allow lifecycle scripts (postinstall, etc.) to run during installation
ignore-scripts=false

# ----------------------------------------------------------------------------
# Package Manager Enforcement
# ----------------------------------------------------------------------------
# Fail installation if Node/pnpm version doesn't match engines in package.json
engine-strict=true

# Enforce use of pnpm - block npm and yarn
package-manager-strict=true

# ----------------------------------------------------------------------------
# Lockfile
# ----------------------------------------------------------------------------
# Always generate and use pnpm-lock.yaml
lockfile=true

# Fail if lockfile is out of sync (CI-friendly)
prefer-frozen-lockfile=true
