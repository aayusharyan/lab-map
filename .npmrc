# pnpm configuration. Docs: https://pnpm.io/npmrc

# Allow lifecycle scripts (postinstall, etc.)
ignore-scripts=false

# Fail if Node/pnpm version doesn't match engines in package.json
engine-strict=true

# Enforce pnpm - block npm and yarn
package-manager-strict=true

# Always use lockfile, fail if out of sync (CI-friendly)
lockfile=true
prefer-frozen-lockfile=true
