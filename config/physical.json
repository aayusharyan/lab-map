    {
      "id": "internet",
      "label": "Internet",
      "type": "generic-internet-1",
      "meta": {
        "hostname": "Internet",
        "role": "WAN / Dual ISP Uplink",
        "ip": "dynamic (ISP-assigned)",
        "note": "Dual ISP feeds — primary fiber 1Gbps symmetric (AS64496), secondary cable 500/50Mbps failover. No BGP; ECMP failover handled by edge-router via CARP. Static /29 public block on primary link."
      }
    },
    {
      "id": "vpn",
      "label": "WireGuard VPN",
      "type": "generic-vpn-1",
      "meta": {
        "hostname": "wg-remote",
        "role": "Remote Worker VPN Tunnel",
        "ip": "10.99.0.0/24",
        "note": "WireGuard tunnel terminated on edge-router. Remote workers receive addresses in 10.99.0.0/24 and access production services via split-tunnel. DNS pushed as 10.0.10.3 (CoreDNS VIP)."
      }
    },
    {
