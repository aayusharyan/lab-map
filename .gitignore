# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
# Node.js package manager directories - reinstall with `pnpm install`
node_modules/

# ----------------------------------------------------------------------------
# Build Output
# ----------------------------------------------------------------------------
# Production build - regenerate with `pnpm build`
dist/

# Vite build cache
.vite/

# TypeScript incremental compilation cache
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Environment & Secrets
# ----------------------------------------------------------------------------
# Local environment variables - NEVER commit secrets
.env
.env.local
.env.*.local
.env.development
.env.production

# ----------------------------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------------------------
# VS Code
.vscode/

# JetBrains (WebStorm, IntelliJ)
.idea/

# Vim/Neovim
*.swp
*.swo
*~

# Sublime Text
*.sublime-workspace
*.sublime-project

# ----------------------------------------------------------------------------
# Operating System
# ----------------------------------------------------------------------------
# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Logs & Debug
# ----------------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
coverage/

# ----------------------------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------------------------
# Claude Code local configuration
.claude/

# Temporary files
*.tmp
*.temp
