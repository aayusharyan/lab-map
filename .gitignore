# Files and directories to exclude from version control.

# Dependencies - reinstall with `pnpm install`
node_modules/

# Build output - regenerate with `pnpm build`
dist/
.vite/
*.tsbuildinfo

# IDE & editors
.vscode/

# OS generated
.DS_Store

# Logs
*.log
pnpm-debug.log*

# User data - copy from examples/ directory
data/
public/data/

# Misc
.claude/
*.tmp
*.temp
